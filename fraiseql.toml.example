# FraiseQL v2.1.0 Configuration Template
#
# Copy to fraiseql.toml in your project root and customize for your environment.
# All fields support ${ENV_VAR} interpolation (expanded before parsing).
# See docs/configuration.md for the full reference.

# =============================================================================
# PROJECT METADATA (required)
# =============================================================================

[schema]
name = "my-fraiseql-app"
version = "1.0.0"
description = "My GraphQL API"
database_target = "postgresql"          # postgresql | mysql | sqlite | sqlserver

# =============================================================================
# DATABASE CONNECTION
# =============================================================================

[database]
url = "${DATABASE_URL}"                 # Connection string (env interpolation)
pool_min = 2                            # Minimum pool connections
pool_max = 20                           # Maximum pool connections
connect_timeout_ms = 5000               # Connection acquisition timeout
idle_timeout_ms = 600_000               # Idle connection lifetime (10 min)
ssl_mode = "prefer"                     # disable | allow | prefer | require

# =============================================================================
# HTTP SERVER
# =============================================================================

[server]
host = "0.0.0.0"
port = 8080
request_timeout_ms = 30_000             # 30 seconds
keep_alive_secs = 75

[server.cors]
origins = []                            # Empty = allow all origins
credentials = false

[server.tls]
enabled = false
cert_file = ""                          # PEM certificate (required if enabled)
key_file = ""                           # PEM private key (required if enabled)
min_version = "1.2"                     # "1.2" or "1.3"

# =============================================================================
# SECURITY
# =============================================================================

[security]
default_policy = "authenticated"        # Default authorization policy name

# --- Error Sanitization ---
[security.error_sanitization]
enabled = true
hide_implementation_details = true      # Strip stack traces, SQL, file paths
sanitize_database_errors = true         # Replace DB errors with generic message
# custom_error_message = "An internal error occurred"

# --- Rate Limiting ---
[security.rate_limiting]
enabled = true
requests_per_second = 100               # Global RPS per IP
burst_size = 200                        # Token bucket burst allowance
# requests_per_second_per_user = 250    # Per-authenticated-user RPS (optional)

# Auth endpoint limits (per-IP)
auth_start_max_requests = 5
auth_start_window_secs = 60
auth_callback_max_requests = 10
auth_callback_window_secs = 60

# Authenticated endpoint limits (per-user)
auth_refresh_max_requests = 20
auth_refresh_window_secs = 300
auth_logout_max_requests = 30
auth_logout_window_secs = 60

# Brute-force protection
failed_login_max_attempts = 10
failed_login_lockout_secs = 900         # 15 minutes
trust_proxy_headers = false             # Trust X-Forwarded-For (set true behind proxy)
# redis_url = "${REDIS_URL}"            # Redis for distributed rate limiting

# --- State Encryption (PKCE OAuth flows) ---
[security.state_encryption]
enabled = true
algorithm = "chacha20-poly1305"         # chacha20-poly1305 | aes-256-gcm
key_source = "env"
key_env = "STATE_ENCRYPTION_KEY"        # Generate: openssl rand -base64 32

# --- PKCE ---
[security.pkce]
enabled = true
code_challenge_method = "S256"          # S256 (recommended) | plain
state_ttl_secs = 600                    # State validity: 10 minutes
# redis_url = "${REDIS_URL}"            # Redis for multi-replica deployments

# --- API Keys ---
# [security.api_keys]
# enabled = true
# header = "X-API-Key"
# hash_algorithm = "sha256"
# storage = "env"                       # "env" or "postgres"
#
# [[security.api_keys.static]]
# key_hash = "sha256:abc123..."         # Pre-hashed key
# scopes = ["read:*"]
# name = "ci-readonly"

# --- Token Revocation ---
# [security.token_revocation]
# enabled = true
# backend = "redis"                     # memory | redis | postgres
# require_jti = true                    # Require JWT jti claim
# fail_open = false                     # false = deny if store unreachable
# redis_url = "${REDIS_URL}"

# --- Trusted Documents (query allowlisting) ---
# [security.trusted_documents]
# enabled = true
# mode = "strict"                       # strict | permissive
# manifest_path = "./trusted-documents.json"
# reload_interval_secs = 0              # 0 = no hot-reload

# --- Authorization Policies ---
# [[security.policies]]
# name = "admin_only"
# type = "RBAC"                         # RBAC | ABAC | CUSTOM | HYBRID
# roles = ["admin", "super_admin"]
# strategy = "ANY"                      # ANY | ALL | EXACTLY
# cache_ttl_seconds = 600

# [[security.field_auth]]
# type_name = "User"
# field_name = "email"
# policy = "admin_only"

# --- Enterprise Security ---
[security.enterprise]
rate_limiting_enabled = true
audit_logging_enabled = true
audit_log_backend = "postgresql"
audit_retention_days = 365
error_sanitization = true
hide_implementation_details = true
constant_time_comparison = true
pkce_enabled = true

# =============================================================================
# AUTHENTICATION (OAuth2/OIDC)
# =============================================================================

# [auth]
# discovery_url = "https://accounts.google.com"
# client_id = "my-fraiseql-client"
# client_secret_env = "OIDC_CLIENT_SECRET"   # Secret via env var (never in TOML)
# server_redirect_uri = "https://api.example.com/auth/callback"

# =============================================================================
# QUERY VALIDATION
# =============================================================================

[validation]
max_query_depth = 10
max_query_complexity = 100

# =============================================================================
# QUERY DEFAULTS
# =============================================================================

[query_defaults]
where = true                            # Auto-add where parameter to list queries
order_by = true                         # Auto-add order_by parameter
limit = true                            # Auto-add limit parameter
offset = true                           # Auto-add offset parameter

# =============================================================================
# CACHING
# =============================================================================

# [caching]
# enabled = true
# backend = "redis"                     # redis | memory | postgresql
# redis_url = "${REDIS_URL}"
#
# [[caching.rules]]
# query = "users"
# ttl_seconds = 300
# invalidation_triggers = ["user_created", "user_updated"]

# =============================================================================
# OBSERVERS (Event System)
# =============================================================================

# [observers]
# enabled = true
# backend = "nats"                      # redis | nats | postgresql | mysql | in-memory
# nats_url = "${FRAISEQL_NATS_URL}"
#
# [[observers.handlers]]
# name = "slack_notifier"
# event = "user_created"
# action = "slack"
# webhook_url = "https://hooks.slack.com/..."
# retry_strategy = "exponential"
# max_retries = 3

# =============================================================================
# SUBSCRIPTIONS (WebSocket)
# =============================================================================

# [subscriptions]
# max_subscriptions_per_connection = 50
#
# [subscriptions.hooks]
# on_connect = "http://localhost:8001/hooks/ws-connect"
# on_subscribe = "http://localhost:8001/hooks/ws-subscribe"
# timeout_ms = 500

# =============================================================================
# FEDERATION (Apollo Federation v2)
# =============================================================================

# [federation]
# enabled = true
# apollo_version = 2
#
# [[federation.entities]]
# name = "Product"
# key_fields = ["id"]
#
# [federation.circuit_breaker]
# enabled = true
# failure_threshold = 5
# recovery_timeout_secs = 30
# success_threshold = 2

# =============================================================================
# OBSERVABILITY
# =============================================================================

# [observability]
# prometheus_enabled = true
# prometheus_port = 9090
# otel_enabled = true
# otel_exporter = "jaeger"
# otel_jaeger_endpoint = "http://localhost:14268/api/traces"
# health_check_enabled = true
# health_check_interval_seconds = 30
# log_level = "info"                    # debug | info | warn | error
# log_format = "json"                   # json | text

# =============================================================================
# MODEL CONTEXT PROTOCOL (MCP)
# =============================================================================

# [mcp]
# enabled = true
# transport = "http"                    # http | stdio | both
# path = "/mcp"
# require_auth = true
# include = []                          # Whitelist (empty = all operations)
# exclude = []                          # Blacklist

# =============================================================================
# DEBUG (development only)
# =============================================================================

# [debug]
# enabled = true
# database_explain = true               # Run EXPLAIN on queries
# expose_sql = true                     # Include generated SQL in response

# =============================================================================
# ANALYTICS (Arrow Flight)
# =============================================================================

# [analytics]
# enabled = true
#
# [[analytics.queries]]
# name = "popular_products"
# sql_source = "SELECT * FROM popular_products"
# description = "Top-selling products"

# =============================================================================
# ENVIRONMENT VARIABLE REFERENCE
#
# DATABASE_URL          — Database connection string
# STATE_ENCRYPTION_KEY  — PKCE state encryption key (openssl rand -base64 32)
# OIDC_CLIENT_SECRET    — OAuth2 client secret
# REDIS_URL             — Redis connection string
# FRAISEQL_NATS_URL     — NATS connection string
# VAULT_ADDR            — HashiCorp Vault address
# VAULT_TOKEN           — Vault authentication token
# =============================================================================
