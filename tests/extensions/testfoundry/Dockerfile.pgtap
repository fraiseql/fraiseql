# PostgreSQL with pgTAP for testing
FROM postgres:16-alpine

# Install build dependencies
RUN apk add --no-cache --virtual .build-deps \
    build-base \
    perl \
    perl-dev \
    wget \
    git

# Install pgTAP
RUN cd /tmp && \
    wget https://github.com/theory/pgtap/archive/v1.3.3.tar.gz && \
    tar -xzf v1.3.3.tar.gz && \
    cd pgtap-1.3.3 && \
    make && \
    make install && \
    cd / && \
    rm -rf /tmp/pgtap-1.3.3 /tmp/v1.3.3.tar.gz

# Clean up build dependencies
RUN apk del .build-deps

# Add pgTAP to shared_preload_libraries
RUN echo "shared_preload_libraries = 'pgtap'" >> /usr/local/share/postgresql/postgresql.conf.sample

# Create extension install script
RUN echo "CREATE EXTENSION IF NOT EXISTS pgtap;" > /docker-entrypoint-initdb.d/01-pgtap.sql
