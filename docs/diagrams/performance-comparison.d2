title: FraiseQL vs Traditional GraphQL

direction: down

traditional: {
  label: "Traditional GraphQL"
  shape: frame

  db1: "PostgreSQL"
  orm1: "ORM Layer"
  deser1: "Deserialize →"
  objects1: "Python Objects"
  gql1: "GraphQL Resolver"
  ser1: "Serialize →"
  json1: "JSON Response"

  db1 -> orm1
  orm1 -> deser1
  deser1 -> objects1
  objects1 -> gql1
  gql1 -> ser1
  ser1 -> json1
}

fraiseql: {
  label: "FraiseQL v2 (Compiled)"
  shape: frame

  db2: "PostgreSQL/MySQL/SQLite/SQL Server"
  direct: "Direct SQL ←"
  json2: "JSONB/Arrow Response"

  db2 -> direct
  direct -> json2
}

comparison: {
  shape: frame

  latency_traditional: "Latency: 150-300ms"
  latency_fraiseql: "Latency: 20-50ms"

  throughput_traditional: "Throughput: 100 req/s"
  throughput_fraiseql: "Throughput: 1000+ req/s"

  overhead_traditional: "Python Overhead: 60-70%"
  overhead_fraiseql: "Python Overhead: 0%"
}

traditional.json1 -> comparison.latency_traditional
fraiseql.json2 -> comparison.latency_fraiseql

traditional.json1 -> comparison.throughput_traditional
fraiseql.json2 -> comparison.throughput_fraiseql

traditional.json1 -> comparison.overhead_traditional
fraiseql.json2 -> comparison.overhead_fraiseql

style: {
  traditional: {
    fill: "#ffebee"
    stroke: "#c62828"
  }
  fraiseql: {
    fill: "#e8f5e9"
    stroke: "#2e7d32"
  }
  comparison: {
    fill: "#fff3e0"
    stroke: "#e65100"
  }
  latency_fraiseql: {
    fill: "#c8e6c9"
    stroke: "#2e7d32"
  }
  latency_traditional: {
    fill: "#ffcdd2"
    stroke: "#c62828"
  }
  throughput_fraiseql: {
    fill: "#c8e6c9"
    stroke: "#2e7d32"
  }
  throughput_traditional: {
    fill: "#ffcdd2"
    stroke: "#c62828"
  }
  overhead_fraiseql: {
    fill: "#c8e6c9"
    stroke: "#2e7d32"
  }
  overhead_traditional: {
    fill: "#ffcdd2"
    stroke: "#c62828"
  }
}
