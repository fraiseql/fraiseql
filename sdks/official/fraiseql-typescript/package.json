{
  "name": "fraiseql",
  "version": "2.1.4",
  "description": "FraiseQL v2 - Compiled GraphQL execution engine (schema authoring + HTTP client)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:tsc": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --strict --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' 'examples/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' 'examples/**/*.ts'",
    "example:basic": "tsx examples/basic_schema.ts",
    "example:analytics": "tsx examples/analytics_schema.ts"
  },
  "keywords": [
    "graphql",
    "database",
    "sql",
    "compiler",
    "schema",
    "http-client",
    "ai",
    "langchain",
    "mastra"
  ],
  "author": "FraiseQL Team",
  "license": "MIT",
  "dependencies": {
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "ai": "^3.0.0",
    "@langchain/core": "^0.1.0",
    "@mastra/core": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    },
    "@mastra/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.0.0",
    "ai": "^4.0.0",
    "@langchain/core": "^0.3.0",
    "@mastra/core": "^0.9.0",
    "eslint": "^9.0.0",
    "msw": "^2.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
