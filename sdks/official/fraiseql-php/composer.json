{
    "name": "fraiseql/fraiseql",
    "description": "FraiseQL PHP SDK — schema authoring and client library",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "FraiseQL Team",
            "email": "team@fraiseql.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-strict-rules": "^1.5",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "FraiseQL\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FraiseQL\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/fraiseql"
    ],
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
