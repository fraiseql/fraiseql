SELECT occurred_at AS occurred_at, revenue AS revenue, AVG(revenue) OVER (ORDER BY occurred_at ASC ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING EXCLUDE CURRENT ROW) AS avg_excluding_current FROM tf_sales
