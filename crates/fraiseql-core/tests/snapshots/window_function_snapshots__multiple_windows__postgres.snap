---
source: crates/fraiseql-core/tests/window_function_snapshots.rs
expression: "plan_and_generate(&query, DatabaseType::PostgreSQL)"
---
SELECT occurred_at AS occurred_at, revenue AS revenue, data->>'category' as category AS data->>'category' as category, ROW_NUMBER() OVER (PARTITION BY data->>'category' ORDER BY revenue DESC) AS row_num, SUM(revenue) OVER (PARTITION BY data->>'category' ORDER BY occurred_at ASC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS running_total, LAG(revenue, 1, 0) OVER (PARTITION BY data->>'category' ORDER BY occurred_at ASC) AS prev_revenue FROM tf_sales
