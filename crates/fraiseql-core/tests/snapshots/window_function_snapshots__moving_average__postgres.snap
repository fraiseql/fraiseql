SELECT occurred_at AS occurred_at, revenue AS revenue, AVG(revenue) OVER (ORDER BY occurred_at ASC ROWS BETWEEN 2 PRECEDING AND CURRENT ROW) AS moving_avg_3 FROM tf_sales
