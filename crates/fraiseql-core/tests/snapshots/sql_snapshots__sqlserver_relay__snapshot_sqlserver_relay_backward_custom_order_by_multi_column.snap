---
source: crates/fraiseql-core/tests/sql_snapshots.rs
expression: sql
---
SELECT data FROM (SELECT data, [id] AS _relay_cursor, JSON_VALUE(data, '$.score') AS _relay_sort_0, JSON_VALUE(data, '$.created_at') AS _relay_sort_1 FROM [v_relay_item] WHERE [id] < CONVERT(UNIQUEIDENTIFIER, @p1) ORDER BY JSON_VALUE(data, '$.score') DESC, JSON_VALUE(data, '$.created_at') ASC, [id] DESC OFFSET 0 ROWS FETCH NEXT @p2 ROWS ONLY) AS _relay_page ORDER BY _relay_sort_0 ASC, _relay_sort_1 DESC, _relay_cursor ASC
