source: crates/fraiseql-core/tests/window_function_snapshots.rs
expression: "plan_and_generate(&query, DatabaseType::PostgreSQL)"
---
SELECT occurred_at AS occurred_at, revenue AS revenue, LAST_VALUE(revenue) OVER (PARTITION BY data->>'category' ORDER BY occurred_at ASC ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) AS last_revenue FROM tf_sales
